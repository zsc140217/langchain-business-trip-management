# ============================================================================
# LangServe API环境变量配置
# ============================================================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 填写真实的API密钥
# 3. 不要将 .env 文件提交到git

# ============================================================================
# 必需配置
# ============================================================================

# 通义千问API密钥（必需）
# 获取地址：https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ============================================================================
# LangSmith追踪（可选 - 用于可观测性）
# ============================================================================

# 启用LangSmith追踪
LANGCHAIN_TRACING_V2=false

# LangSmith API密钥
# 获取地址：https://smith.langchain.com/settings
LANGCHAIN_API_KEY=your_langsmith_api_key_here

# LangSmith项目名称
LANGCHAIN_PROJECT=business-trip-management

# LangSmith端点（通常不需要修改）
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ============================================================================
# 服务配置
# ============================================================================

# API服务端口
PORT=8000

# API服务主机
HOST=0.0.0.0

# 日志级别 (debug|info|warning|error)
LOG_LEVEL=info

# ============================================================================
# Redis缓存（可选 - Module 7需要）
# ============================================================================

# Redis主机
REDIS_HOST=localhost

# Redis端口
REDIS_PORT=6379

# Redis密码（如果设置了密码）
REDIS_PASSWORD=

# Redis数据库编号
REDIS_DB=0

# ============================================================================
# 安全配置（生产环境）
# ============================================================================

# CORS允许的来源（逗号分隔，生产环境应限制具体域名）
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# API密钥认证（可选）
# API_KEY=your_api_key_for_authentication

# ============================================================================
# 性能配置
# ============================================================================

# 最大并发请求数
# MAX_WORKERS=4

# 请求超时时间（秒）
# REQUEST_TIMEOUT=300

# ============================================================================
# 开发模式（仅开发环境）
# ============================================================================

# 启用热重载（开发模式）
# RELOAD=true

# 启用详细日志
# DEBUG=true
